---
import { getCollection } from 'astro:content'
import type { Lang } from '@/i18n/ui'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const chosenByItems = await getCollection('chosenBy')
const sectionTitle = lang === 'ua' ? 'Нас обирають' : 'They Choose Us'
---

<section class="our-partners section section--dark dark-bg">
  <div class="container">
    <div class="title-container-h2">
      <h2 class="typography-h2">{sectionTitle}</h2>
    </div>
    <div class="our-partners__marquee">
      <ul class="our-partners__list">
        {chosenByItems.map((item) => (
          <li class="our-partners__item">
            <img
              src={item.data.logo}
              alt={item.data.text}
              class="our-partners__item-image"
            />
            <p class="our-partners__item-text">{item.data.text}</p>
          </li>
        ))}
        {chosenByItems.map((item) => (
          <li class="our-partners__item">
            <img
              src={item.data.logo}
              alt={item.data.text}
              class="our-partners__item-image"
            />
            <p class="our-partners__item-text">{item.data.text}</p>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
