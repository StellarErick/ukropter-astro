---
interface Props {
  data: {
    sectionTitle: string
    steps: string[]
    videoTitle: string
    videos: string[]
  }
}

const { data } = Astro.props
---

<section class="section section--dark dark-bg reviews order-process">
  <div class="container">
    <div class="title-container-h2">
      <h2 class="typography-h2">{data.sectionTitle}</h2>
    </div>
    <ul class="order-process__list">
      {data.steps.map((step, i) => {
        const num = String(i + 1).padStart(2, '0')
        return (
          <li class="order-process__item">
            <p class="order-process__item-text">
              <span class="text-stack">
                <span class="text-base typography-h3 order-process__item-text-number">{num}</span>
                <span aria-hidden="true" class="text-pattern typography-h3 order-process__item-text-pattern">{num}</span>
              </span>
              <span class="order-process__item-text-title"> {step} </span>
            </p>
          </li>
        )
      })}
    </ul>

    <p class="order-process__video-title">{data.videoTitle}</p>

    <div class="video-container">
      <div class="splide our-developments__splide" id="our-developments-splide" data-slides-count="3" data-enable-modal="true">
        <div class="splide__track">
          <ul class="splide__list">
            {data.videos.map(src => (
              <li class="splide__slide">
                <div class="order-process__video-container">
                  <video src={src} class="order-process__video" preload="auto" muted poster=""></video>
                  <button class="order-process__slide-video-play">
                    <svg width="30" height="30"><use href="/images/sprite.svg#icon-play"></use></svg>
                  </button>
                  <div class="order-process__video-overlay"></div>
                </div>
              </li>
            ))}
          </ul>
          <div class="splider-custom__arrows-container">
            <div class="splider-custom__arrows-custom">
              <button class="splider-custom__arrow splider-custom__arrow--prev-custom">
                <svg width="18" height="16"><use href="/images/sprite.svg#icon-splide-prev"></use></svg>
              </button>
              <button class="splider-custom__arrow splider-custom__arrow--next-custom">
                <svg width="18" height="16"><use href="/images/sprite.svg#icon-splide-next"></use></svg>
              </button>
            </div>
            <div class="about-company__splide-pagination splide__pagination"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
